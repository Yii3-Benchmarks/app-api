BASE_URL=http://localhost:9991
TARGET_NAME=home
TARGET_PATH=/
BENCH_NAME=PHP-FPM + Nginx
BENCH_SCRIPT=bench-ramp.js
CAPTURE_METRICS=1
RATE=10000
DURATION=160s
START_RATE=500
TIME_UNIT=1s
PREALLOCATED_VUS=10000
MAX_VUS=100000
VUS_SIZING_MODE=auto
PEAK_RATE=50000
AUTO_MAX_VUS_LIMIT=500000
STAGES=[{"target":5000,"duration":"30s"},{"target":10000,"duration":"30s"},{"target":15000,"duration":"30s"},{"target":20000,"duration":"30s"},{"target":25000,"duration":"30s"},{"target":30000,"duration":"30s"},{"target":40000,"duration":"30s"},{"target":50000,"duration":"30s"}]
DOCKER_STATS_INTERVAL=1
DOCKER_STATS_APP_SERVICES=php nginx
DOCKER_STATS_SERVICES=postgres valkey
COMPOSE_PROJECT_NAME=yii3-benchmarks-php-fpm
K6_LOG_OUTPUT=none
